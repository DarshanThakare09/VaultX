<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:gravity="center"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Set Your PIN"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_marginBottom="30dp"/>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:id="@+id/pinDots"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="40dp">

        <View style="@style/PinDot"/>
        <View style="@style/PinDot"/>
        <View style="@style/PinDot"/>
        <View style="@style/PinDot"/>
    </LinearLayout>

    <GridLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:id="@+id/keypadGrid"
        android:columnCount="3"
        android:rowCount="4">

        <Button style="@style/PinKey" android:text="1"/>
        <Button style="@style/PinKey" android:text="2"/>
        <Button style="@style/PinKey" android:text="3"/>

        <Button style="@style/PinKey" android:text="4"/>
        <Button style="@style/PinKey" android:text="5"/>
        <Button style="@style/PinKey" android:text="6"/>

        <Button style="@style/PinKey" android:text="7"/>
        <Button style="@style/PinKey" android:text="8"/>
        <Button style="@style/PinKey" android:text="9"/>

        <View style="@style/PinKeyEmpty"/>
        <Button style="@style/PinKey" android:text="0"/>
        <Button
            android:id="@+id/btnDelete"
            style="@style/PinKey"
            android:text="⌫"/>
    </GridLayout>
</LinearLayout>