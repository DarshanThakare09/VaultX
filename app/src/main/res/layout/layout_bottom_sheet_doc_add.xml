<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_gradient"
    android:padding="24dp">

    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:background="#40FFFFFF"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="20dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Add to Files"
        android:textColor="@android:color/white"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp"/>

    <!-- Write a text document -->
    <LinearLayout
        android:id="@+id/btn_doc_write"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingVertical="14dp"
        android:gravity="center_vertical"
        android:background="?attr/selectableItemBackground">
        <ImageView android:layout_width="28dp" android:layout_height="28dp" android:src="@android:drawable/ic_menu_edit" app:tint="#FFB74D"/>
        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical" android:layout_marginStart="16dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Write Text Document" android:textColor="@android:color/white" android:textSize="16sp" android:textStyle="bold"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Create a new plain-text note" android:textColor="#80FFFFFF" android:textSize="12sp"/>
        </LinearLayout>
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#20FFFFFF" android:layout_marginVertical="4dp"/>

    <!-- Import a file -->
    <LinearLayout
        android:id="@+id/btn_doc_import"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingVertical="14dp"
        android:gravity="center_vertical"
        android:background="?attr/selectableItemBackground">
        <ImageView android:layout_width="28dp" android:layout_height="28dp" android:src="@android:drawable/ic_menu_upload" app:tint="#64B5F6"/>
        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical" android:layout_marginStart="16dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Import File" android:textColor="@android:color/white" android:textSize="16sp" android:textStyle="bold"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="PDF, DOCX, XLSX, images &amp; more" android:textColor="#80FFFFFF" android:textSize="12sp"/>
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
