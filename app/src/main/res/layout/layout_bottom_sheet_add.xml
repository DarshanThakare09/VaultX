<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_gradient"
    android:padding="24dp">

    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:background="#40FFFFFF"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="24dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Add to Vault"
        android:textColor="@android:color/white"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp"/>

    <LinearLayout
        android:id="@+id/btn_add_document"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingVertical="12dp"
        android:gravity="center_vertical"
        android:background="?attr/selectableItemBackground">
        <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/ic_menu_edit" app:tint="#64B5F6"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Create Document" android:textColor="@android:color/white" android:layout_marginStart="16dp" android:textSize="16sp"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/btn_add_photo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingVertical="12dp"
        android:gravity="center_vertical"
        android:background="?attr/selectableItemBackground">
        <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/ic_menu_gallery" app:tint="#81C784"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Import Photo" android:textColor="@android:color/white" android:layout_marginStart="16dp" android:textSize="16sp"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/btn_add_password"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingVertical="12dp"
        android:gravity="center_vertical"
        android:background="?attr/selectableItemBackground">
        <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/ic_lock_lock" app:tint="#E57373"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Save Password" android:textColor="@android:color/white" android:layout_marginStart="16dp" android:textSize="16sp"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/btn_add_note"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingVertical="12dp"
        android:gravity="center_vertical"
        android:background="?attr/selectableItemBackground">
        <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/ic_menu_agenda" app:tint="#FFB74D"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Create Secure Note" android:textColor="@android:color/white" android:layout_marginStart="16dp" android:textSize="16sp"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/btn_scan_document"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingVertical="12dp"
        android:gravity="center_vertical"
        android:background="?attr/selectableItemBackground">
        <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/ic_menu_camera" app:tint="#BA68C8"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Scan Document" android:textColor="@android:color/white" android:layout_marginStart="16dp" android:textSize="16sp"/>
    </LinearLayout>

</LinearLayout>
