<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:gravity="center"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp"
    android:background="@drawable/bg_gradient">

    <!-- Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Enter PIN"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#111"
        android:layout_marginBottom="30dp"/>

    <!-- PIN DOTS -->
    <LinearLayout
        android:id="@+id/pinDots"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="40dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content">

        <View style="@style/PinDot"/>
        <View style="@style/PinDot"/>
        <View style="@style/PinDot"/>
        <View style="@style/PinDot"/>

    </LinearLayout>

    <!-- KEYPAD -->
    <GridLayout
        android:id="@+id/keypadGrid"
        android:columnCount="3"
        android:rowCount="4"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content">

        <!-- Numbers -->
        <!-- Row 1 -->
        <Button style="@style/PinKey" android:text="1"/>
        <Button style="@style/PinKey" android:text="2"/>
        <Button style="@style/PinKey" android:text="3"/>

        <!-- Row 2 -->
        <Button style="@style/PinKey" android:text="4"/>
        <Button style="@style/PinKey" android:text="5"/>
        <Button style="@style/PinKey" android:text="6"/>

        <!-- Row 3 -->
        <Button style="@style/PinKey" android:text="7"/>
        <Button style="@style/PinKey" android:text="8"/>
        <Button style="@style/PinKey" android:text="9"/>

        <!-- Row 4 -->
        <View style="@style/PinKeyEmpty"/>
        <Button style="@style/PinKey" android:text="0"/>
        <Button
            android:id="@+id/btnDelete"
            style="@style/PinKey"
            android:text="⌫"/>
    </GridLayout>

</LinearLayout>