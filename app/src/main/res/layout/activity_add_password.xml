<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@drawable/bg_gradient"
    android:id="@+id/main">
    
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="24dp">

        <TextView
            android:id="@+id/tv_add_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="New Password"
            android:textColor="@android:color/white"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginTop="32dp"
            android:layout_marginStart="24dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <Button
            android:id="@+id/btn_save"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Save"
            android:layout_marginEnd="16dp"
            app:backgroundTint="#E57373"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/tv_add_title"
            app:layout_constraintBottom_toBottomOf="@id/tv_add_title"/>

        <EditText
            android:id="@+id/et_pass_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Account/App Name"
            android:textColorHint="#80FFFFFF"
            android:textColor="@android:color/white"
            android:textSize="18sp"
            android:padding="16dp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="24dp"
            android:background="#1AFFFFFF"
            android:inputType="textCapSentences"
            app:layout_constraintTop_toBottomOf="@id/tv_add_title" />

        <EditText
            android:id="@+id/et_pass_website"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Website URL (Optional)"
            android:textColorHint="#80FFFFFF"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:padding="16dp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="16dp"
            android:background="#1AFFFFFF"
            android:inputType="textUri"
            app:layout_constraintTop_toBottomOf="@id/et_pass_title" />

        <EditText
            android:id="@+id/et_pass_user"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Username / Email"
            android:textColorHint="#80FFFFFF"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:padding="16dp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="16dp"
            android:background="#1AFFFFFF"
            android:inputType="textEmailAddress"
            app:layout_constraintTop_toBottomOf="@id/et_pass_website" />

        <LinearLayout
            android:id="@+id/layout_password_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="16dp"
            android:background="#1AFFFFFF"
            app:layout_constraintTop_toBottomOf="@id/et_pass_user">
            
            <EditText
                android:id="@+id/et_pass_code"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Password"
                android:textColorHint="#80FFFFFF"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                android:padding="16dp"
                android:background="@android:color/transparent"
                android:inputType="textPassword" />
                
            <ImageButton
                android:id="@+id/btn_toggle_visibility"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_view"
                app:tint="#B3FFFFFF"/>
        </LinearLayout>
        
        <Button
            android:id="@+id/btn_generate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Generate Secure Password"
            style="?attr/materialButtonOutlinedStyle"
            app:strokeColor="#B3FFFFFF"
            android:textColor="#FFFFFF"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/layout_password_input"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
